{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "noImplicitAny": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "./public/js"
    },
    "include": [
        "resources/js/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
